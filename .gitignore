<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Get a $500 Target Gift Card</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --red: #8b1a1a;
      --red-light: #a52020;
      --bg: #e8e6e3;
      --card-bg: #f0eeeb;
      --text: #1a1a1a;
      --text-muted: #555;
    }

    body {
      font-family: 'Source Sans 3', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    .hero {
      text-align: center;
      padding: 64px 20px 10px;
    }
    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(40px, 6vw, 64px);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.5px;
      margin-bottom: 20px;
    }
    .hero p {
      font-size: 16px;
      color: var(--text-muted);
      max-width: 400px;
      margin: 0 auto 36px;
      line-height: 1.6;
    }
    .hero-buttons {
      display: flex;
      justify-content: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .btn-primary {
      text-decoration: none;
      background: var(--red);
      color: #fff;
      border: none;
      padding: 14px 28px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: background 0.2s;
      font-family: inherit;
    }
    .btn-primary:hover { background: var(--red-light); }
    .btn-primary .arrow { font-size: 18px; }
    .btn-secondary {
      text-decoration: none;
      background: transparent;
      color: var(--text);
      border: 2px solid #ccc;
      padding: 14px 28px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      transition: border-color 0.2s;
      font-family: inherit;
    }
    .btn-secondary:hover { border-color: #999; }

    .offers {
      padding: 70px 20px 60px;
      max-width: 860px;
      margin: 0 auto;
    }
    .offers h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(24px, 3.5vw, 34px);
      font-weight: 700;
      text-align: center;
      margin-bottom: 40px;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 560px) {
      .cards-grid { grid-template-columns: 1fr; }
    }
    .card {
      background: var(--card-bg);
      border-radius: 14px;
      padding: 24px 22px;
      border: 1px solid rgba(0,0,0,0.07);
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .card:hover {
      box-shadow: 0 6px 20px rgba(0,0,0,0.11);
      transform: translateY(-2px);
    }
    .card-header {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 10px;
    }
    .step-badge {
      width: 32px; height: 32px;
      background: var(--red);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }
    .card h3 {
      font-size: 16px;
      font-weight: 700;
      line-height: 1.3;
    }
    .card p {
      font-size: 13.5px;
      color: var(--text-muted);
      line-height: 1.55;
      padding-left: 46px;
    }

    .cta {
      text-align: center;
      padding: 20px 20px 80px;
    }
    .cta h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(22px, 3vw, 30px);
      font-weight: 700;
      margin-bottom: 12px;
    }
    .cta p {
      font-size: 15px;
      color: var(--text-muted);
      margin-bottom: 28px;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero          { animation: fadeUp 0.5s ease both; animation-delay: 0.1s; }
    .offers h2     { animation: fadeUp 0.5s ease both; animation-delay: 0.2s; }
    .card:nth-child(1) { animation: fadeUp 0.5s ease both; animation-delay: 0.25s; }
    .card:nth-child(2) { animation: fadeUp 0.5s ease both; animation-delay: 0.32s; }
    .card:nth-child(3) { animation: fadeUp 0.5s ease both; animation-delay: 0.39s; }
    .card:nth-child(4) { animation: fadeUp 0.5s ease both; animation-delay: 0.46s; }
    .cta           { animation: fadeUp 0.5s ease both; animation-delay: 0.5s; }

    .popup-notification {
      position: fixed;
      top: 20px;
      left: 50%;
      transform: translateX(-50%) translateY(-10px);
      background: white;
      border-radius: 999px;
      padding: 8px 18px 8px 10px;
      box-shadow: 0 4px 18px rgba(0,0,0,0.13);
      font-family: 'Source Sans 3', Arial, sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: #1a1a1a;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      opacity: 0;
      white-space: nowrap;
      transition: opacity 0.4s ease, transform 0.4s ease;
      z-index: 9999;
      pointer-events: none;
    }
    .popup-notification.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    .popup-check-icon {
      width: 20px; height: 20px;
      background: #22a745;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .popup-check-icon svg { width: 10px; height: 10px; }
  </style>
</head>
<body>

  <div class="popup-notification" id="popupNotif">
    <div class="popup-check-icon">
      <svg viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 5.5L4 7.5L8 3" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <span id="popupText"></span>
  </div>

  <section class="hero">
    <h1>Get a $500<br>Target Gift Card</h1>
    <p>Explore limited-time Target-related offers, discounts, and savings programs people are checking right now.</p>
    <div class="hero-buttons">
      <a href="https://linkthem.net/aff_c?offer_id=317&aff_id=158635" target="_blank" class="btn-primary">Get the $500 Gift Card <span class="arrow">&#8250;</span></a>
      <a href="https://linkthem.net/aff_c?offer_id=317&aff_id=158635" target="_blank" class="btn-secondary">Check Available Deals</a>
    </div>
  </section>

  <section class="offers">
    <h2>Explore limited-time Target-related offers</h2>
    <div class="cards-grid">
      <div class="card">
        <div class="card-header">
          <div class="step-badge">1</div>
          <h3>Enter basic information</h3>
        </div>
        <p>Provide your details to get started and access personalized offers tailored to you.</p>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="step-badge">2</div>
          <h3>Complete a quick verification step</h3>
        </div>
        <p>A simple verification process to ensure security and authenticity of your account.</p>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="step-badge">3</div>
          <h3>Explore available offers</h3>
        </div>
        <p>Browse through curated Target offers and savings programs available for you.</p>
      </div>
      <div class="card">
        <div class="card-header">
          <div class="step-badge">4</div>
          <h3>Access gift card rewards</h3>
        </div>
        <p>Unlock and access your Target gift card rewards once you complete the program.</p>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Ready to get started?</h2>
    <p>Join thousands exploring Target savings and rewards programs.</p>
    <a href="https://linkthem.net/aff_c?offer_id=317&aff_id=158635" target="_blank" class="btn-primary">Get the $500 Gift Card <span class="arrow">&#8250;</span></a>
  </section>

  <script>
    var notifications = [
      "Ashley from Texas just accessed the savings program",
      "Maria from California unlocked the rewards offer",
      "Jordan from Ohio just claimed their $500 gift card",
      "Kevin from Arizona accessed the savings program",
      "Brittany from Nevada just received the $500 gift card",
      "Marcus from Georgia unlocked the rewards program",
      "Jessica from Illinois just claimed the $500 reward",
      "Chris from Pennsylvania accessed the savings program",
      "Amanda from North Carolina received the $500 gift card"
    ];
    var currentIndex = 0;
    var popup = document.getElementById('popupNotif');
    var popupText = document.getElementById('popupText');

    function showNext() {
      popupText.textContent = notifications[currentIndex];
      currentIndex = (currentIndex + 1) % notifications.length;
      popup.classList.add('show');
      setTimeout(function() {
        popup.classList.remove('show');
        setTimeout(showNext, 5400);
      }, 3000);
    }

    setTimeout(showNext, 5000);
  </script>

</body>
</html>
